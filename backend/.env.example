# Environment mode
NODE_ENV=production

# Server Port
PORT=10000

# JWT Secret Key
JWT_SECRET=your_jwt_secret_key_here

# Frontend URL (CORS)
CLIENT_URL=https://your-frontend-app.onrender.com

# Database Connection (Option 1: URL)
# DATABASE_URL=mysql://user:password@host:3306/quizbattle

# Database Connection (Option 2: Individual variables)
DB_HOST=your-db-host.com
DB_PORT=3306
DB_USER=your_db_username
DB_PASSWORD=your_db_password
DB_NAME=quizbattle
DB_SSL=true
